# BankAccount class
# A class is a blueprint for creating bank account objects.

class BankAccount:

    # Constructor method
    # Runs automatically when a new account is created.
    def __init__(self, account_holder, balance=0):

        # Store the account holder's name
        self.account_holder = account_holder

        # Store the starting balance
        self.balance = balance

    # Deposit money into the account
    def deposit(self, amount):

        # Check if the deposit amount is positive
        if amount > 0:

            # Add the amount to the balance
            self.balance += amount

            # Display confirmation message
            print(f"₹{amount} deposited.")

        else:
            # Invalid deposit amount
            print("Deposit amount must be positive.")

    # Withdraw money from the account
    def withdraw(self, amount):

        # Check if withdrawal amount is positive
        if amount <= 0:
            print("Withdrawal amount must be positive.")

        # Check if enough money is available
        elif amount > self.balance:
            print("Insufficient funds.")

        else:
            # Subtract amount from balance
            self.balance -= amount

            # Display confirmation message
            print(f"₹{amount} withdrawn.")

    # Display the current balance
    def show_balance(self):

        # Print current account balance
        print(f"Current Balance: ₹{self.balance}")


# --------------------------------------------------
# Create a new bank account object
# Account holder = Kirti
# Starting balance = ₹1000
# --------------------------------------------------

account = BankAccount("Kirti", 1000)

# Display initial balance
account.show_balance()

# Deposit ₹500
account.deposit(500)

# Withdraw ₹300
account.withdraw(300)

# Display final balance
account.show_balance()
